{
  "Format": "2.0.0",
  "Changes": [
    {
      "LogName": "Wayward Wings - Includes",
      "Action": "Include",
      "FromFile": "Data/Includes.json",
    },
  ],
  // CONFIG OPTIONS
  "ConfigSchema": {
    "TimeBetweenLetters": {
      "AllowValues": "ThreeDays, FiveDays, SevenDays, TenDays, FourteenDays",
      "Default": "SevenDays",
      "AllowBlank": false,
      "Description": "Configures the minimum amount of time between Argent's casual letters.",
      "Section": "Gameplay",
    },
    "NonhumanFarmer": {
      "AllowValues": "true, false",
      "Default": false,
      "Description": "For roleplay/narrative purposes: alters some dialogue. If you consider your character to be nonhuman or immortal, check this box.",
      "Section": "Narrative",
    },
    "Player Pronouns 1": {
      "Default": "They",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Sets the player's desired pronouns.",
      "Section": "Pronouns"
    },
    "Player Pronouns 2": {
      "Default": "Them",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Sets the player's desired pronouns.",
      "Section": "Pronouns"
    },
    "Player Pronouns 3": {
      "Default": "Theirs",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Sets the player's desired pronouns.",
      "Section": "Pronouns"
    },
    "Player Pronouns 4": {
      "Default": "Themselves",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Sets the player's desired pronouns.",
      "Section": "Pronouns"
    },
    "Player Pronoun Identifier": {
      "Default": "are",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Would usually be \"is\" or \"are\", depending on context. Example: She IS so cool! VS. They ARE so cool!",
      "Section": "Pronouns"
    },
  },
  // DYNAMIC TOKENS
  "DynamicTokens": [
    {
      "Name": "PlayerPronouns",
      "Value": "|CPPN1={{Random: {{Player Pronouns 1}} |key=PlayerPronouns}} |CPPN2={{Random: {{Player Pronouns 2}} |key=PlayerPronouns}} |CPPN3={{Random: {{Player Pronouns 3}} |key=PlayerPronouns}} |CPPN4={{Random: {{Player Pronouns 4}} |key=PlayerPronouns}} |CPPNI={{Random: {{Player Pronoun Identifier}} |key=PlayerPronouns}} |LPPN1={{Random: {{Lowercase: {{Player Pronouns 1}}}} |key=PlayerPronouns}} |LPPN2={{Random: {{Lowercase: {{Player Pronouns 2}}}} |key=PlayerPronouns}} |LPPN3={{Random: {{Lowercase: {{Player Pronouns 3}}}} |key=PlayerPronouns}} |LPPN4={{Random: {{Lowercase: {{Player Pronouns 4}}}} |key=PlayerPronouns}} |LPPNI={{Random: {{Lowercase: {{Player Pronoun Identifier}}}} |key=PlayerPronouns}}"
    },
    {
      "Name": "WeekDayList",
      "Value": "Sun, Mon, Tue, Wed, Thu, Fri, Sat"
    },
    {
      "Name": "WeekDay",
      "Value": "{{WeekDayList |valueAt={{Query: {{Day}}%7}}}}"
    },
    {
      "Name": "NHF",
      "Value": "Human",
      "When": {"NonHumanFarmer": false}
    },
    {
      "Name": "NHF",
      "Value": "Nonhuman",
      "When": {"NonHumanFarmer": true}
    },
    {
      "Name": "NHF",
      "Value": "Nonhuman",
      "When": {"NonhumanFarmer": true}
    },
    {
      "Name": "MailCooldown",
      "Value": "2",
      "When": {"TimeBetweenLetters": "ThreeDays"}
    },
    {
      "Name": "MailCooldown",
      "Value": "4",
      "When": {"TimeBetweenLetters": "FiveDays"}
    },
    {
      "Name": "MailCooldown",
      "Value": "6",
      "When": {"TimeBetweenLetters": "SevenDays"}
    },
    {
      "Name": "MailCooldown",
      "Value": "9",
      "When": {"TimeBetweenLetters": "TenDays"}
    },
    {
      "Name": "MailCooldown",
      "Value": "13",
      "When": {"TimeBetweenLetters": "FourteenDays"}
