	"Spam.IsAnyoneHere": "Hello?^^^Is anyone there?^^^Hello?",
	"Spam.IsAnyoneHereDesc": "Hello?",
	
	"Spam.WeKnow": "We know what you did, @.^^^We're waiting.",
	"Spam.WeKnowDesc": "We Know",
	
