	// prank calls (2.0 feature)
	"UnknownCaller": "Unknown",
	"Calls.HangUp": "%Whoever called you immediately hung up...",
	"Calls.Fridge.1": "Hey, is your refrigerator running? #$b#It is? Well, you better go catch it! Ahahaha! *click*",
	"Calls.Fridge.2": "Hey, is your refrigerator running? #$b#Oh, it's... It's not? Uhh, you should probably get that fixed. *click*",
	"Calls.Fridge.3": "Hey, is your refrigerator--What, you've heard this one already? #$b#Ugh, never mind... *click*",
	"Calls.NoFridge.1": "Hey, is your refrigerator running? ...Wait, what do you mean you don't have a fridge? #$b#Are you, like, okay? Where do you put your food? #$b#Man, this is kinda awkward... *click*",
	"Calls.NoFridge.2": "Hey, is your refrigerator running? Oh, wait a minute. I remember you from the last time! #$b#So you do have a fridge now? Great to hear it, man. Good on ya. Well, hope you're having a good one. *click*",
	"Calls.Horse.1": "Hey, is your horse running? #$b#I would really hope so! Ahahaha! *click*",
	"Calls.Horse.Marnie": "Hey, is your horse running? #$b#It's really important that you give them lots of exercise! Let me know if you need help training them, okay?$1",
	"Calls.HorseWarranty": "Hello. We are calling to remind you of your horse's expired warranty. #$b#You are qualified for an extension. Please call us back to apply.",


	//config
	"config.SpamMail.name": "Spam Mail",
	"config.SpamMail.Description": "Enables spam mail. A bunch of weird, silly, and sometimes useful letters may appear in your mailbox. The core of the mod! Also enables conversation topics.",
	"config.OminousMail.name": "Ominous Mail",
	"config.OminousMail.description": "Enables spam mail with more \"ominous\" tones. They don't have any effect on the game, they're just less silly and more creepy. Does nothing is Spam Mail is disabled.",
	"config.GetAllParentalMail.name": "Both Parents Send Mail",
	"config.GetAllParentalMail.description": "If enabled, you will get letters from both Mom and Dad instead of only one of them (or their equivalents, if Remixed Parental Mail is enabled). This also slightly changes when they're sent to space them out.",
	"config.ParentalMail.name": "Remixed Parental Mail",
	"config.ParentalMail.description": "Enable this if you'd like the milestone letters sent from Mom or Dad to be replaced with something different. This also changes the rewards they give.",
	"config.PrankCalls.name": "Prank Calls",
	"config.PrankCalls.description": "Allows you to get prank calls! The spam mail of a new era.",
	"config.RepeatCalls.name": "Repeatable Calls",
	"config.RepeatCalls.description": "Enables certain phone calls to repeat. In the base game, phone calls received by the player will only appear once per save file.",
	"Config.OminousPrankCalls.name": "Ominous Prank Calls",
	"Config.OminousPrankCalls.description": "Allows you to get ominous prank calls. Does nothing if Prank Calls are disabled.",
